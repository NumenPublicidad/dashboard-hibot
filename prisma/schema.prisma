generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UploadBatch {
  id           String        @id @default(cuid())
  fileName     String
  rowCount     Int
  createdAt    DateTime      @default(now())
  interactions Interaction[]
}

model Interaction {
  id String @id @default(cuid())

  uploadBatchId String
  uploadBatch   UploadBatch @relation(fields: [uploadBatchId], references: [id], onDelete: Cascade)

  uploadedAt DateTime @default(now())

  conversationId        String?
  agent                 String?
  contactName           String?
  contactPhone          String?
  email                 String?
  tags                  String?
  inactivityCount       Int?
  direction             String?
  contactType           String?
  channelType           String?
  channel               String?
  client                String?
  parentAgent           String?
  parentConversationId  String?
  project               String?
  campaign              String?
  assignmentMethod      String?
  typification          String?
  subTypification       String?
  startDate             DateTime?
  delegationDate        DateTime?
  assignmentDate        DateTime?
  waitTimeSeconds       Int?
  attentionHour         String?
  responseTimeSeconds   Int?
  endDate               DateTime?
  durationSeconds       Int?
  delegationState       String?
  notes                 String?
  status                String?

  raw Json?

  @@index([uploadBatchId])
  @@index([uploadedAt])
  @@index([startDate])
  @@index([typification])
  @@index([status])
}
model HibotWebhookEvent {
  id        String   @id @default(cuid())
  eventType String?
  raw       Json
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
}

model HibotConversation {
  id String @id

  active Boolean?
  type   String?

  createdAtHibot  DateTime?
  assignedAtHibot DateTime?
  closedAtHibot   DateTime?

  typing String?
  notes  String?

  agentId    String?
  agentName  String?
  agentEmail String?

  clientId   String?
  clientName String?

  projectId   String?
  projectName String?

  campaignId   String?
  campaignName String?

  channelId      String?
  channelName    String?
  channelType    String?
  channelAccount String?

  asa         Float?
  creationAsa Float?

  raw Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages HibotMessage[]

  @@index([agentName])
  @@index([channelType])
  @@index([createdAtHibot])
  @@index([assignedAtHibot])
  @@index([closedAtHibot])
}

model HibotMessage {
  id String @id

  correlationId String?

  conversationId String
  conversation   HibotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAtHibot DateTime?

  sender    String?
  recipient String?

  from      String?
  content   String?
  media     String?
  mediaType String?

  status           String?
  errorDescription String?

  raw Json?

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([from])
  @@index([createdAtHibot])
  @@index([status])
}